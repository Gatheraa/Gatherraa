#!/bin/sh
# Pre-commit hook to verify Rust contract formatting

echo "=== Running cargo fmt check ==="
# Move to the contract directory relative to the repository root
cd "$(git rev-parse --show-toplevel)/contract" || exit 1

cargo fmt --all -- --check
status=$?

if [ $status -ne 0 ]; then
    echo "❌ Error: Cargo formatting check failed!"
    echo "Please run 'cargo fmt --all' in the contract directory to fix formatting issues before committing."
    exit 1
fi

echo "✅ Cargo formatting check passed."
exit 0
